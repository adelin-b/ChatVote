# ──────────────────────────────────────────────
# Backend Deployment (K8s — NOT the serverless container)
# ──────────────────────────────────────────────
# NOTE: The K8s deployment and the Scaleway Serverless Container
# (scaleway_container.backend_prod) are two separate backends.
# Currently, prod traffic goes through the Serverless Container.
# The K8s deployment is used for internal/pipeline access.

resource "kubernetes_deployment" "backend" {
  metadata {
    name      = "chatvote-backend"
    namespace = kubernetes_namespace.chatvote.metadata[0].name
    labels    = { app = "chatvote-backend" }
  }

  spec {
    replicas = 1

    strategy {
      type = "RollingUpdate"
      rolling_update {
        max_surge       = 1
        max_unavailable = 0
      }
    }

    selector {
      match_labels = { app = "chatvote-backend" }
    }

    template {
      metadata {
        labels = { app = "chatvote-backend" }
      }

      spec {
        service_account_name             = kubernetes_service_account.backend.metadata[0].name
        termination_grace_period_seconds = 75

        node_selector = {
          "k8s.scaleway.com/pool-name" = scaleway_k8s_pool.main.name
        }

        image_pull_secrets {
          name = kubernetes_secret.registry.metadata[0].name
        }

        container {
          name  = "backend"
          image = var.backend_image

          port {
            container_port = 8080
            name           = "http"
          }

          lifecycle {
            pre_stop {
              exec {
                command = ["/bin/sh", "-c", "sleep 10"]
              }
            }
          }

          startup_probe {
            http_get {
              path = "/healthz"
              port = 8080
            }
            period_seconds    = 5
            failure_threshold = 30
            timeout_seconds   = 3
          }

          liveness_probe {
            http_get {
              path = "/healthz"
              port = 8080
            }
            period_seconds    = 15
            failure_threshold = 3
            timeout_seconds   = 5
          }

          readiness_probe {
            http_get {
              path = "/health"
              port = 8080
            }
            period_seconds    = 10
            failure_threshold = 3
            timeout_seconds   = 10
          }

          resources {
            requests = {
              memory = "512Mi"
              cpu    = "250m"
            }
            limits = {
              memory = "2Gi"
              cpu    = "2000m"
            }
          }

          env_from {
            secret_ref {
              name = kubernetes_secret.backend_env.metadata[0].name
            }
          }
        }
      }
    }
  }
}

# ──────────────────────────────────────────────
# Backend Service (LoadBalancer)
# ──────────────────────────────────────────────

resource "kubernetes_service" "backend" {
  metadata {
    name      = "chatvote-backend"
    namespace = kubernetes_namespace.chatvote.metadata[0].name
    labels    = { app = "chatvote-backend" }

    annotations = {
      # HTTP protocol for WebSocket Upgrade headers
      "service.beta.kubernetes.io/scw-loadbalancer-protocol-http"   = "8080"
      # 10-minute timeouts for streaming LLM responses
      "service.beta.kubernetes.io/scw-loadbalancer-timeout-server"  = "600000"
      "service.beta.kubernetes.io/scw-loadbalancer-timeout-client"  = "600000"
      "service.beta.kubernetes.io/scw-loadbalancer-timeout-tunnel"  = "600000"
    }
  }

  spec {
    type     = "LoadBalancer"
    selector = { app = "chatvote-backend" }

    port {
      name        = "http"
      port        = 8080
      target_port = 8080
      protocol    = "TCP"
    }
  }
}
