{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en,fr",
  "dictionaries": ["fr-fr", "typescript", "python", "node", "npm", "html", "css", "project-words"],
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": ".cspell/project-words.txt",
      "addWords": true
    }
  ],
  "ignorePaths": [
    "node_modules",
    ".next",
    ".pnpm-store",
    "pnpm-lock.yaml",
    "poetry.lock",
    "package-lock.json",
    "*.min.js",
    "*.min.css",
    "megalinter-reports",
    "firebase",
    "__pycache__",
    "*.pdf",
    ".git",
    ".omc",
    ".claude"
  ]
}
