# ============================================================================
# ChatVote Frontend — Local Development Environment
# ============================================================================
# Copy this file to .env.local:  cp .env.local.template .env.local
# All values below work out-of-the-box with `make dev` (no API keys needed
# for infrastructure — but you need at least one LLM key for AI chat).
# ============================================================================

# ── Firebase Client SDK (emulator mode — fake values, emulators don't validate) ──
NEXT_PUBLIC_FIREBASE_API_KEY=fake-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=localhost
NEXT_PUBLIC_FIREBASE_PROJECT_ID=chat-vote-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=chat-vote-dev.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:fake
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX  # GA4 — leave unset in dev

# ── Firebase Admin SDK (server-side — not needed with emulators) ──
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# ── App URLs ──
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Qdrant (vector DB — auto-started by docker-compose) ──
QDRANT_URL=http://localhost:6333
ENV=dev

# ── LLM / Embedding API Keys (need at least one for AI chat) ──
SCALEWAY_EMBED_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
# PERPLEXITY_API_KEY=           # Optional — enables web search fallback

# ── Langfuse Observability (auto-provisioned by docker-compose) ──
LANGFUSE_SECRET_KEY=sk-lf-local
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_BASEURL=http://localhost:8652
NEXT_PUBLIC_LANGFUSE_PUBLIC_KEY=pk-lf-local
NEXT_PUBLIC_LANGFUSE_HOST=http://localhost:8652

# ── RAGFlow (optional — start with RAGFLOW=1 make dev) ──
# Default login: admin@chatvote.local / chatvote123
# Get API key from: http://localhost:8680 → user avatar → API Keys
RAGFLOW_API_URL=http://localhost:8680
RAGFLOW_API_KEY=

# ── Vercel Toolbar (dev only) ──
FLAGS_SECRET=local-dev-secret
