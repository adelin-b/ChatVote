API_NAME=chatvote-api
# ENV=local uses Firebase Emulators + Ollama (no cloud keys needed)
# ENV=dev uses cloud Firebase dev project
# ENV=prod uses cloud Firebase production project
ENV=local

# === LOCAL DEVELOPMENT (default — no API keys needed) ===
QDRANT_URL=http://localhost:6333
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_DIM=768
EMBEDDING_PROVIDER=ollama

# === Cloud API keys (uncomment to use cloud LLMs instead of Ollama) ===
# GOOGLE_API_KEY=your_google_api_key
# OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key
# AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key
# OPENAI_API_VERSION=2024-08-01-preview
# QDRANT_API_KEY=your_qdrant_api_key
# QDRANT_URL=your_qdrant_url
# GOOGLE_APPLICATION_CREDENTIALS=

# === Scaleway (OpenAI-compatible) ===
# SCALEWAY_EMBED_API_KEY=your_scaleway_key  # GitHub secret: QWEN3_8B_SCW_SECRET_KEY
# SCALEWAY_EMBED_BASE_URL=https://api.scaleway.ai/78c3d473-15a8-46bf-9c9a-339d618c75b5/v1
# SCALEWAY_EMBED_MODEL=qwen3-embedding-8b
# SCALEWAY_EMBED_DIM=4096
# SCALEWAY_LLM_MODEL=llama-3.3-70b-instruct  # Scaleway LLM fallback (used via ChatOpenAI)

# === Apify (social media scraping for candidates without websites) ===
# APIFY_API_KEY=your_apify_key

# === Force a specific embedding provider (auto-detect if unset) ===
# EMBEDDING_PROVIDER=  # google | scaleway | openai | ollama

# === Firebase (cloud mode only — not needed for ENV=local) ===
# FIREBASE_CREDENTIALS_BASE64=  # base64-encoded service account JSON
# FIREBASE_STORAGE_BUCKET=chat-vote-dev.appspot.com  # needed for manifesto PDF indexer

# === Admin dashboard ===
# ADMIN_SECRET=  # SHA-256 hash used as URL path for admin dashboard
# ADMIN_UPLOAD_SECRET=  # secret for document upload endpoint

# === Google Sheets (for coverage data export) ===
# GOOGLE_SHEETS_CREDENTIALS_BASE64=  # base64-encoded service account JSON

# === LangSmith tracing (optional) ===
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=your_langchain_api_key
# LANGCHAIN_PROJECT=chat-vote-dev
