# === LOCAL DEVELOPMENT (zero cloud keys needed) ===
API_NAME=chatvote-api
ENV=local

# Firebase emulator
FIRESTORE_EMULATOR_HOST=localhost:8081

# Vector DB (Docker)
QDRANT_URL=http://localhost:6333

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_DIM=768

# LangChain tracing (optional — leave blank to disable)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=chat-vote-local

# Cloud LLM keys (optional — Ollama is used by default in local mode)
# GOOGLE_API_KEY=
# OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# PERPLEXITY_API_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=  # Leave commented out for local dev
