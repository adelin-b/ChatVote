# Development Dockerfile with hot-reload support

FROM python:3.11.3-slim

# Install system dependencies for Playwright browsers
RUN apt-get update && apt-get install -y \
    # Playwright dependencies
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libdbus-1-3 \
    libxkbcommon0 \
    libatspi2.0-0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libpango-1.0-0 \
    libcairo2 \
    # Additional utilities
    wget \
    && rm -rf /var/lib/apt/lists/*

# Upgrade pip first to avoid corruption issues
RUN pip install --upgrade pip setuptools wheel

# Install Poetry
RUN pip install poetry

# Copy only the necessary files for Poetry (to leverage Docker layer caching)
COPY pyproject.toml poetry.lock /app/

WORKDIR /app

# Configure poetry to not create virtual env (use system python)
RUN poetry config virtualenvs.create false

# Install dependencies
RUN poetry install --no-root

# Install Playwright browsers (Chromium only for smaller image)
RUN playwright install chromium
RUN playwright install-deps chromium

# Install watchfiles for hot-reload
RUN pip install watchfiles

# Copy the rest of the application code
COPY . /app

# Use watchfiles to auto-reload on code changes
CMD ["watchfiles", "--filter", "python", "python -m src.aiohttp_app --host 0.0.0.0 --port 8080", "./src"]
